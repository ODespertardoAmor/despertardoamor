<!DOCTYPE html>
<html lang="pt-br">
<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>D/Amor</title>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>

        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:'Poppins',sans-serif;
        }

        body{
            background:#0f172a;
            color:white;
        }

        .topo{

            background:#111827;
            padding:15px;
            display:flex;
            flex-direction:column;
            gap:20px;
            position:sticky;
            top:0;
            z-index:1000;
            border-bottom:2px solid #38bdf8;

        }

        .logo{

            font-size:28px;
            font-weight:bold;
            color:#38bdf8;
            text-align:center;

        }

        .menu-superior{

            display:flex;
            justify-content:center;
            gap:10px;
            flex-wrap:wrap;

        }

        .btn{

            background:#2563eb;
            color:white;
            padding:10px 16px;
            text-decoration:none;
            border-radius:12px;
            border:none;
            cursor:pointer;
            font-size:14px;
            transition:0.3s;
            position:relative;

        }

        .btn:hover{
            background:#1d4ed8;
        }

        .notificacao{

            position:absolute;
            top:-8px;
            right:-8px;
            background:#ef4444;
            color:white;
            min-width:22px;
            height:22px;
            border-radius:50%;
            display:flex;
            align-items:center;
            justify-content:center;
            font-size:12px;
            font-weight:bold;

        }

        .area-perfil{

            display:flex;
            flex-direction:column;
            align-items:center;
            gap:15px;

        }

        .perfil-info{

            display:flex;
            align-items:center;
            gap:12px;
            background:#0f172a;
            padding:10px 15px;
            border-radius:20px;

        }

        .nome-user{

            font-size:16px;
            font-weight:bold;
            color:#38bdf8;

        }

        .avatar-user{

            width:70px;
            height:70px;
            border-radius:50%;
            object-fit:cover;
            border:3px solid #38bdf8;

        }

        .avatar-form{

            display:flex;
            flex-direction:column;
            align-items:center;
            gap:10px;
            width:100%;

        }

        .avatar-form input[type="file"]{

            background:#0f172a;
            color:white;
            padding:10px;
            border-radius:12px;
            width:100%;
            max-width:300px;
            border:1px solid #334155;

        }

        .container{

            padding:20px;

        }

        .titulo{

            text-align:center;
            margin-bottom:25px;
            color:#38bdf8;

        }

        .card{

            background:#1e293b;
            padding:20px;
            border-radius:24px;
            margin-bottom:20px;
            display:flex;
            flex-direction:column;
            align-items:center;
            text-align:center;
            border:1px solid #334155;

        }

        .avatar-outro{

            width:120px;
            height:120px;
            border-radius:50%;
            object-fit:cover;
            margin-bottom:15px;
            border:3px solid #38bdf8;

        }

        .card h2{

            margin-bottom:10px;
            color:#38bdf8;

        }

        .card p{

            margin-bottom:8px;
            color:#d1d5db;

        }

        .acoes{

            margin-top:20px;
            display:flex;
            gap:10px;
            width:100%;

        }

        .acoes .btn{

            flex:1;
            text-align:center;

        }

        @media(min-width:768px){

            .topo{

                flex-direction:row;
                justify-content:space-between;
                align-items:center;

            }

            .logo{
                text-align:left;
            }

            .menu-superior{
                justify-content:flex-start;
            }

            .area-perfil{
                flex-direction:row;
            }

            .avatar-form{
                flex-direction:row;
                width:auto;
            }

            .container{

                max-width:1100px;
                margin:auto;

            }

        }

    </style>

</head>
<body>

    <div class="topo">

        <div class="logo">
            💙 D/Amor
        </div>


        <div class="menu-superior">

            <a href="/" class="btn">
                Home
            </a>

            <a href="/matches" class="btn">
                Matches

                {% if total_notificacoes > 0 %}
                    <span class="notificacao">
                        {{ total_notificacoes }}
                    </span>
                {% endif %}

            </a>

            <a href="/logout" class="btn">
                Sair
            </a>

        </div>


        <div class="area-perfil">

            <div class="perfil-info">

                <img
                    src="{{ url_for('static', filename='uploads/' + usuario_logado.foto) }}"
                    class="avatar-user"
                >

                <div class="nome-user">
                    {{usuario_logado.nome}}
                </div>

            </div>

            <form
                action="/upload_foto"
                method="POST"
                enctype="multipart/form-data"
                class="avatar-form"
            >

                <input
                    type="file"
                    name="foto"
                    required
                >

                <button
                    type="submit"
                    class="btn"
                >
                    Alterar Foto
                </button>

            </form>

        </div>

    </div>


    <div class="container">

        <h1 class="titulo">
            Pessoas disponíveis
        </h1>

        {% for u in usuarios %}

        <div class="card">

            <img
                src="{{ url_for('static', filename='uploads/' + u.foto) }}"
                class="avatar-outro"
            >

            <h2>
                {{u.nome}}, {{u.idade}}
            </h2>

            <p>
                📍 {{u.cidade}}
            </p>

            <p>
                {{u.bio}}
            </p>

            <div class="acoes">

                <a href="/curtir/{{u.id}}" class="btn">
                    Curtir
                </a>

                <a href="/chat/{{u.id}}" class="btn">
                    Chat
                </a>

            </div>

        </div>

        {% endfor %}

    </div>

</body>
</html>
